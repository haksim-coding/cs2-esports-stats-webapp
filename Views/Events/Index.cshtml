@model IReadOnlyList<cs2_esports.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 text-primary fw-bold mb-0">Events</h1>
</div>

<div class="cs2-glass-card shadow-lg p-0 overflow-hidden border-0 events-table">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="cs2-table-head">
                <tr>
                    <th class="ps-4">Event Name</th>
                    <th>Organizer</th>
                    <th>Tier</th>
                    <th>Location</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var tournament in Model)
            {
                var isSTier = tournament.Tier == cs2_esports.Models.EventTier.S;
                var tierClass = tournament.Tier == cs2_esports.Models.EventTier.S ? "event-tier-gold" : tournament.Tier == cs2_esports.Models.EventTier.A ? "event-tier-green" : "event-tier-neutral";
                <tr class="clickable-row border-top border-secondary @(isSTier ? "event-s-tier-row" : string.Empty)" onclick="window.location='@Url.Action("Details", new { id = tournament.Id })'">
                    <td class="fw-bold text-light ps-4 py-3">
                        <i class="bi bi-trophy-fill text-accent me-2"></i> @tournament.Name
                    </td>
                    <td class="text-secondary"><i class="bi bi-building text-muted me-1"></i> @tournament.Organizer</td>
                    <td>
                        <span class="badge @tierClass px-2 py-1 shadow-sm">@tournament.Tier</span>
                    </td>
                    <td class="text-light fw-medium">
                        <i class="bi bi-geo-alt-fill text-muted me-1"></i>
                        <img src="@CountryFlagHelper.GetFlagImageUrl(tournament.EventVenue?.CountryCode)" alt="@tournament.EventVenue?.CountryCode flag" class="country-flag-img country-flag--inline" loading="lazy" decoding="async" />
                        @tournament.EventVenue?.City
                    </td>
                    <td class="text-secondary small">
                        <i class="bi bi-calendar-event me-1"></i>
                        @tournament.StartDateUtc.ToString("MMM dd") - @tournament.EndDateUtc.ToString("MMM dd, yyyy")
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
