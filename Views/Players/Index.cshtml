@model IReadOnlyList<cs2_esports.Models.Player>
@{
    ViewData["Title"] = "Players";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 text-primary fw-bold mb-0">Active Players</h1>
</div>

<div class="cs2-glass-card p-0 overflow-hidden shadow-lg border-0 players-table">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="cs2-table-head">
                <tr>
                    <th class="ps-4">Player</th>
                    <th>Role</th>
                    <th>Team</th>
                    <th>Country</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var player in Model)
            {
                <tr class="clickable-row border-top border-secondary" onclick="window.location='@Url.Action("Details", new { id = player.Id })'">
                    <td class="ps-4 py-3">
                        <div class="d-flex flex-column">
                            <strong class="text-light fs-5 fw-bold text-decoration-none">@player.Nickname</strong>
                            <span class="text-muted small">@player.FullName</span>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-black border border-secondary text-info p-2 shadow-sm">@player.Role</span>
                    </td>
                    <td>
                        @if (player.Team != null)
                        {
                            var teamLogoPath = TeamLogoResolver.GetLogoPath(player.Team.Name, player.Team.Tag);
                            <a asp-controller="Teams" asp-action="Details" asp-route-id="@player.Team.Id" class="team-mention-link" onclick="event.stopPropagation();">
                                @if (!string.IsNullOrWhiteSpace(teamLogoPath))
                                {
                                    <img src="@Url.Content(teamLogoPath)" class="team-logo" alt="@player.Team.Name logo" />
                                }
                                else
                                {
                                    <span class="team-logo-fallback">@TeamLogoResolver.GetBadgeText(player.Team.Name, player.Team.Tag)</span>
                                }
                                <span class="badge bg-black border border-primary text-light p-2 shadow-sm">@player.Team.Name</span>
                            </a>
                        }
                        else
                        {
                            <span class="text-secondary small fst-italic">Free Agent</span>
                        }
                    </td>
                    <td class="text-secondary fw-semibold">
                        <i class="bi bi-geo-alt-fill text-muted me-1"></i>
                        <img src="@CountryFlagHelper.GetFlagImageUrl(player.CountryCode)" alt="@player.CountryCode flag" class="country-flag-img country-flag--inline" loading="lazy" decoding="async" />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>