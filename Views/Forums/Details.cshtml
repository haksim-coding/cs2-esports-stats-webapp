@model cs2_esports.Models.ForumDetailsViewModel
@{
    ViewData["Title"] = Model.Forum.Title;
}
<div class="esports-card mb-5 p-4">
    <h1 class="h2 text-light fw-bold mb-3">@Model.Forum.Title</h1>
    <div class="d-flex flex-wrap align-items-center gap-2 mb-4 pb-3" style="border-bottom: 1px solid #2d3340;">
    <span class="badge border border-info text-info bg-transparent px-3 py-2 rounded-pill">@Model.Forum.Category</span>
    @if (Model.Forum.IsPinned)
    {
            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Pinned</span>
        }
        @if (Model.Forum.IsLocked)
        {
            <span class="badge bg-secondary text-light px-3 py-2 rounded-pill">&#128274; Locked</span>
        }
        <div class="ms-auto text-muted small d-flex gap-3 mt-2 mt-md-0">
            <span>By <strong class="text-primary">@Model.Forum.Author?.DisplayName</strong></span>
            <span>Created @Model.Forum.CreatedAtUtc.ToString("yy-MM-dd HH:mm")</span>
            <span><span class="text-info">&#128065;</span> @Model.Forum.ViewCount views</span>
        </div>
    </div>
    <div class="text-light fs-5 mb-4" style="line-height: 1.6; white-space: pre-line;">
        @Model.Forum.Content
    </div>
    @if (Model.Forum.Event is not null)
    {
        <div class="mt-4 pt-3" style="border-top: 1px dashed rgba(255,255,255,0.1);">
            <span class="text-secondary small me-2">Related Event:</span>
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Forum.Event.Id" class="badge bg-dark border border-secondary text-light text-decoration-none p-2 cs2-btn-glow">
                @Model.Forum.Event.Name
            </a>
        </div>
    }
</div>

<h4 class="text-info mb-4" style="text-shadow: 0 0 8px rgba(34, 211, 238, 0.4);">Comments <span class="badge bg-primary rounded-circle ms-2 px-2 py-1">@Model.Comments.Count</span></h4>
<div class="d-flex flex-column gap-3 mb-5">
    @if (!Model.Comments.Any())
    {
        <div class="text-muted fst-italic p-4 text-center cs2-glass-card">No comments yet. Be the first to share your thoughts.</div>
    }
    else
    {
        foreach (var comment in Model.Comments)
        {
            <div class="cs2-glass-card p-3">
                <div class="d-flex justify-content-between mb-2 border-bottom pb-2" style="border-color: rgba(255,255,255,0.05)!important">
                    <span class="fw-bold text-light">@comment.Author?.DisplayName</span>
                    <small class="text-muted">@comment.CreatedAtUtc.ToString("yy-MM-dd HH:mm")</small>
                </div>
                <div class="text-light" style="white-space: pre-line;">
                    @comment.Content
                </div>
            </div>
        }
    }
</div>

@if (Model.Forum.IsLocked)
{
    <div class="cs2-glass-card p-4 text-center border border-secondary text-muted">
        &#128274; This thread is locked. No new comments can be added.
    </div>
}
else if (Model.CurrentUser == null)
{
    <div class="cs2-glass-card p-4 text-center border border-secondary mt-3 text-muted">
        <p>You must be logged in to post a reply.</p>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-info">Login</a>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary ms-2">Register</a>
    </div>
}
else
{
    <div class="esports-card mt-4">
        <h5 class="text-light mb-3">Add a Reply</h5>
        <form asp-action="Comment" method="post">
            <input type="hidden" name="ForumId" value="@Model.Forum.Id" />
            <input type="hidden" name="AuthorId" value="@Model.CurrentUser.Id" />

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="text-danger mb-3 small fw-semibold auth-validation"></div>
            }

            <div class="mb-3">
                <label for="Content" class="form-label text-info">Message</label>
                <textarea id="Content" name="Content" class="form-control cs2-input" rows="4" placeholder="Enter your response here...">@Model.NewComment.Content</textarea>
            </div>

            <button type="submit" class="btn btn-primary px-4 py-2 mt-2">Post Reply</button>
        </form>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .dropdown-dark { background-color: #111827; color: #fff; }
        .dropdown-dark option { background-color: #111827; }
    </style>
}
