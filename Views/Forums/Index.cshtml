@model IReadOnlyList<cs2_esports.Models.Forum>
@{
    ViewData["Title"] = "Forums";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 text-primary fw-bold mb-0">Forum Threads</h1>
    <a asp-action="Create" class="btn btn-primary px-4 fw-bold shadow-sm">Create Thread</a>
</div>

<div class="cs2-glass-card table-responsive p-0 border-0 shadow-lg">
    <table class="table table-hover align-middle mb-0">
        <thead class="cs2-table-head">
            <tr>
                <th class="ps-4">Title</th>
                <th>Category</th>
                <th>Author</th>
                <th>Views</th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var forum in Model)
        {
            <tr class="clickable-row border-top border-secondary" onclick="window.location.href='@Url.Action("Details", "Forums", new { id = forum.Id })'">
                <td class="text-light fw-semibold ps-4 py-3">
                    <div class="d-flex align-items-center">
                        @if (forum.IsPinned)
                        {
                            <span class="badge bg-warning text-dark me-2 small"><i class="bi bi-pin-angle-fill"></i> Pinned</span>
                        }
                        @if (forum.IsLocked)
                        {
                            <span class="badge bg-secondary text-light me-2 small"><i class="bi bi-lock-fill"></i> Locked</span>
                        }
                        <span class="fs-6">@forum.Title</span>
                    </div>
                </td>
                <td><span class="badge border border-info text-info bg-transparent">@forum.Category</span></td>
                <td class="text-muted"><i class="bi bi-person-circle me-1"></i> @forum.Author?.DisplayName</td>
                <td class="text-secondary"><i class="bi bi-eye text-muted me-1"></i> @forum.ViewCount</td>
                <td class="text-muted small">@forum.LastUpdatedAtUtc.ToString("yy-MM-dd HH:mm")</td>
            </tr>
        }
        </tbody>
    </table>
</div>